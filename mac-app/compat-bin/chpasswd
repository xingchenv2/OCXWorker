#!/bin/bash
# ──────────────────────────────────────────────────────────────
# chpasswd — macOS compat wrapper for OCX Worker
#
# Linux `chpasswd` reads "user:password" lines from stdin.
# macOS has no chpasswd; we implement it with dscl.
# ──────────────────────────────────────────────────────────────
set -euo pipefail

# chpasswd supports: [-e] (encrypted) [-m] (md5)
ENCRYPTED=false
while getopts "em" opt 2>/dev/null; do
    case "$opt" in
        e) ENCRYPTED=true ;;
        m) ;; # ignore, macOS dscl handles hashing
        *) echo "chpasswd (macOS compat): unknown option -$opt" >&2; exit 1 ;;
    esac
done

# Read "username:password" from stdin
while IFS= read -r line; do
    [ -z "$line" ] && continue
    user="${line%%:*}"
    pass="${line#*:}"

    if [ -z "$user" ] || [ -z "$pass" ]; then
        echo "chpasswd (macOS compat): invalid input format" >&2
        exit 1
    fi

    if [ "$ENCRYPTED" = true ]; then
        # -e flag: password is already encrypted
        # dscl doesn't support setting pre-hashed password easily
        # Use openssl + dscl for hashed input
        echo "$pass" | dscl . -passwd "/Users/$user" - 2>/dev/null || {
            # Fallback: try using dsimport for encrypted passwords
            echo "chpasswd (macOS compat): -e (encrypted) mode not fully supported on macOS, attempting plaintext fallback" >&2
            dscl . -passwd "/Users/$user" "$pass" 2>/dev/null
        }
    else
        # Plaintext password — dscl handles the hashing
        dscl . -passwd "/Users/$user" "$pass" 2>/dev/null || {
            # If dscl fails (e.g. root user or OD user), try passwd command
            echo "$user:$pass" | sudo -S passwd "$user" 2>/dev/null || true
        }
    fi
done

exit 0
