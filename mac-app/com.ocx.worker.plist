<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ocx.worker</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/macOS OCX.app/Contents/MacOS/launch.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Applications/macOS OCX.app/Contents/Resources/data/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Applications/macOS OCX.app/Contents/Resources/data/logs/launchd-stderr.log</string>
    <key>WorkingDirectory</key>
    <string>/Applications/macOS OCX.app/Contents/Resources</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Applications/macOS OCX.app/Contents/Resources/compat-bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
