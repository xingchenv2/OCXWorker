#!/bin/bash
# ──────────────────────────────────────────────────────────────
# macOS OCX — Main Launcher (CFBundleExecutable)
#
# Double-click → starts backend → opens native in-app window.
# Zero external dependencies. Works on every Mac out of the box.
#
# Key design decisions:
#   - Data lives in ~/Library/Application Support/macOS OCX/
#     (NOT inside the .app bundle — Gatekeeper makes .app read-only)
#   - App Translocation: macOS may run from a temp copy, so we
#     resolve the real bundle path when needed
#   - Native window via osacompile (built-in, ~1s on first run)
#   - Fallback: Safari in app mode if osacompile fails
# ──────────────────────────────────────────────────────────────
set -uo pipefail

APP_NAME="macOS OCX"
SERVER_PORT=8818

# ── Resolve bundle path (survives App Translocation) ──────────
# When Gatekeeper translocates, $0 points to a read-only temp copy.
# We need the real .app location for copying resources, but data
# must go to a writable location outside the bundle.
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
BUNDLE="$(cd "${SCRIPT_PATH}/.." && pwd)"

# For resources (JAR, JRE, schema), we use the bundle path.
# For writable data, we use ~/Library/Application Support/.
RESOURCES="${BUNDLE}/Resources"
MACOS="${BUNDLE}/MacOS"
APP_DIR="${RESOURCES}/app"
COMPAT_DIR="${RESOURCES}/compat-bin"
JAR_FILE="${APP_DIR}/ocx-worker.jar"
SCHEMA_FILE="${APP_DIR}/schema-sqlite.sql"

# ── Writable data directory (outside .app bundle!) ────────────
# This is the macOS-standard location for app support data.
# Gatekeeper/App Translocation makes the .app bundle read-only,
# so we cannot put databases, logs, or keys inside it.
DATA_DIR="${HOME}/Library/Application Support/macOS OCX"
KEYS_DIR="${DATA_DIR}/keys"
LOG_DIR="${DATA_DIR}/logs"
BACKUP_DIR="${DATA_DIR}/backups"
DB_FILE="${DATA_DIR}/ocx-worker.db"

# ── Compiled window applet (also in writable location) ────────
WINDOW_APP="${DATA_DIR}/Window.applet"

# ── Setup logging ──────────────────────────────────────────────
mkdir -p "$LOG_DIR" "$KEYS_DIR" "$BACKUP_DIR" "$DATA_DIR"
LOG_FILE="${LOG_DIR}/launch.log"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG_FILE"; }
log "═══════════════════════════════════════════"
log "$APP_NAME starting..."
log "Bundle:  $BUNDLE"
log "Data:    $DATA_DIR"
log "Home:    $HOME"

# ── Step 1: First-run — compile native window via osacompile ──
# osacompile is built into every macOS (no Xcode needed).
# Output goes to the writable data directory.
if [ ! -d "$WINDOW_APP" ]; then
    log "First run: compiling native window..."
    
    /usr/bin/osacompile -x -o "$WINDOW_APP" "${MACOS}/entry.applescript" >> "$LOG_FILE" 2>&1
    
    if [ -d "$WINDOW_APP" ]; then
        log "Window applet compiled OK"
        /usr/bin/plutil -replace LSUIElement -bool NO "$WINDOW_APP/Contents/Info.plist" 2>/dev/null || true
    else
        log "WARNING: osacompile failed, will use Safari fallback"
        WINDOW_APP=""
    fi
fi

# ── Step 2: Detect JRE ────────────────────────────────────────
ARCH="$(uname -m)"
case "$ARCH" in
    arm64|aarch64)  RUNTIME_DIR="${RESOURCES}/runtime-arm64" ;;
    x86_64|x64)     RUNTIME_DIR="${RESOURCES}/runtime-x64" ;;
    *)              RUNTIME_DIR="${RESOURCES}/runtime-arm64" ;;
esac

JAVA=""

# ── Fix JRE permissions (zip may strip +x) ───────────────────
# macOS unzip often loses executable permissions.
# We fix them before checking.
if [ -d "$RUNTIME_DIR" ]; then
    chmod -R u+X "$RUNTIME_DIR" 2>/dev/null || true
    log "Fixed JRE permissions in $RUNTIME_DIR"
fi

for candidate in \
    "$RUNTIME_DIR"/*/zulu-*.jre/Contents/Home/bin/java \
    "$RUNTIME_DIR"/*/Contents/Home/bin/java \
    "$RUNTIME_DIR"/*/Home/bin/java; do
    if [ -x "$candidate" ]; then
        JAVA="$candidate"
        break
    fi
done

# Also check non-executable java — zip may have stripped +x
if [ -z "$JAVA" ]; then
    for candidate in \
        "$RUNTIME_DIR"/*/zulu-*.jre/Contents/Home/bin/java \
        "$RUNTIME_DIR"/*/Contents/Home/bin/java \
        "$RUNTIME_DIR"/*/Home/bin/java; do
        if [ -f "$candidate" ]; then
            chmod +x "$candidate" 2>/dev/null && JAVA="$candidate"
            [ -n "$JAVA" ] && break
        fi
    done
fi

# Also try resolving through the real .app path (not translocated)
if [ -z "$JAVA" ] || [ ! -x "$JAVA" ]; then
    # App Translocation workaround: try finding JRE relative to
    # any macOS OCX.app in /Applications or user's known location
    for alt_bundle in \
        "/Applications/macOS OCX.app" \
        "${HOME}/Applications/macOS OCX.app" \
        "${HOME}/Desktop/macOS OCX.app"; do
        if [ -d "$alt_bundle" ]; then
            ALT_RT="$alt_bundle/Contents/Resources/runtime-${ARCH}"
            # Fix permissions for alternate bundle too
            chmod -R u+X "$ALT_RT" 2>/dev/null || true
            for candidate in \
                "$ALT_RT"/*/zulu-*.jre/Contents/Home/bin/java \
                "$ALT_RT"/*/Contents/Home/bin/java \
                "$ALT_RT"/*/Home/bin/java; do
                if [ -x "$candidate" ]; then
                    JAVA="$candidate"
                    RUNTIME_DIR="$ALT_RT"
                    log "JRE found at alternate bundle: $alt_bundle"
                    break 2
                fi
            done
            # Also try non-executable (permission stripped by zip)
            for candidate in \
                "$ALT_RT"/*/zulu-*.jre/Contents/Home/bin/java \
                "$ALT_RT"/*/Contents/Home/bin/java \
                "$ALT_RT"/*/Home/bin/java; do
                if [ -f "$candidate" ]; then
                    chmod +x "$candidate" 2>/dev/null && JAVA="$candidate"
                    RUNTIME_DIR="$ALT_RT"
                    [ -n "$JAVA" ] && log "JRE found (fixed +x) at alternate bundle: $alt_bundle" && break 2
                fi
            done
        fi
    done
fi

if [ -z "$JAVA" ] || [ ! -x "$JAVA" ]; then
    if command -v java &>/dev/null; then
        JAVA="$(command -v java)"
        log "Using system Java"
    else
        # Last resort: find any java file in runtime dir and chmod it
        LAST_RESORT="$(find "$RUNTIME_DIR" -name java -type f 2>/dev/null | head -1)"
        if [ -n "$LAST_RESORT" ]; then
            chmod +x "$LAST_RESORT" 2>/dev/null
            JAVA="$LAST_RESORT"
            log "JRE found via find+chmod: $LAST_RESORT"
        else
            log "FATAL: No Java found! RUNTIME_DIR=$RUNTIME_DIR"
            log "FATAL: Directory contents:"
            ls -laR "$RUNTIME_DIR" >> "$LOG_FILE" 2>/dev/null || log "FATAL: $RUNTIME_DIR does not exist"
            /usr/bin/osascript -e "display dialog \"$APP_NAME 无法启动\\n\\n未找到 Java 运行时\\n请重新下载完整安装包\" with title \"$APP_NAME\" buttons {\"OK\"} default button \"OK\" with icon stop" 2>/dev/null
            exit 1
        fi
    fi
fi

log "Java: $JAVA ($ARCH)"

# ── Step 3: Setup compat-bin + secure data dirs ───────────────
export PATH="${COMPAT_DIR}:${PATH}"
chmod 700 "$DATA_DIR" 2>/dev/null || true
chmod 700 "$KEYS_DIR" 2>/dev/null || true
[ -f "$DB_FILE" ] && chmod 600 "$DB_FILE" 2>/dev/null || true

# ── Step 4: Initialize SQLite database ────────────────────────
if [ ! -f "$DB_FILE" ]; then
    SQLITE3="$(command -v sqlite3 2>/dev/null || true)"
    if [ -n "$SQLITE3" ] && [ -f "$SCHEMA_FILE" ]; then
        log "Initializing SQLite database..."
        "$SQLITE3" "$DB_FILE" < "$SCHEMA_FILE"
        chmod 600 "$DB_FILE"
        log "Database created at $DB_FILE"
    else
        log "sqlite3 CLI not found or schema missing — will rely on Spring Boot auto-init"
    fi
fi

# ── Step 5: Start Spring Boot backend ──────────────────────────
log "Starting backend on :$SERVER_PORT..."

# Note: -Dloader.path uses APP_DIR which is inside .app (read-only,
# that's fine — it's just adding SQLite JDBC to classpath).
# All writable paths (DB, keys, logs) are outside the bundle.
"$JAVA" \
    -Dloader.main=com.ociworker.OciWorkerApplication \
    -Dloader.path="${APP_DIR}/" \
    -cp "$JAR_FILE" \
    org.springframework.boot.loader.launch.PropertiesLauncher \
    --spring.datasource.driver-class-name=org.sqlite.JDBC \
    --spring.datasource.url="jdbc:sqlite:${DB_FILE}?journal_mode=WAL&busy_timeout=5000&foreign_keys=on" \
    --spring.datasource.username=sa \
    --spring.datasource.password= \
    --spring.sql.init.mode=always \
    --spring.sql.init.schema-locations=classpath:schema-sqlite.sql \
    --spring.sql.init.continue-on-error=true \
    --server.port="$SERVER_PORT" \
    --oci-cfg.key-dir-path="$KEYS_DIR" \
    --logging.file.name="${LOG_DIR}/spring.log" \
    ${OCX_EXTRA_JAVA_OPTS:-} \
    >> "${LOG_DIR}/backend.log" 2>&1 &

BACKEND_PID=$!
log "Backend PID: $BACKEND_PID"

# ── Cleanup ────────────────────────────────────────────────────
cleanup() {
    log "Shutting down..."
    kill $BACKEND_PID 2>/dev/null || true
    wait $BACKEND_PID 2>/dev/null || true
    log "Goodbye"
}
trap cleanup EXIT

# ── Step 6: Wait for backend ready ─────────────────────────────
log "Waiting for backend..."
ATTEMPTS=0
MAX_ATTEMPTS=120

while [ $ATTEMPTS -lt $MAX_ATTEMPTS ]; do
    ATTEMPTS=$((ATTEMPTS + 1))
    HTTP_CODE=$(curl -s -o /dev/null -w '%{http_code}' "http://localhost:$SERVER_PORT" 2>/dev/null || echo "000")
    if echo "$HTTP_CODE" | grep -qE '^[23]'; then
        log "Backend ready! (HTTP $HTTP_CODE, ${ATTEMPTS}s)"
        break
    fi
    sleep 1
done

if [ $ATTEMPTS -ge $MAX_ATTEMPTS ]; then
    log "FATAL: Backend startup timeout (${MAX_ATTEMPTS}s)"
    log "--- Last 30 lines of backend.log ---"
    tail -30 "${LOG_DIR}/backend.log" >> "$LOG_FILE" 2>/dev/null || true
    /usr/bin/osascript -e "display dialog \"$APP_NAME 启动失败\\n\\n服务启动超时，请查看日志：\\n${LOG_DIR}/backend.log\" with title \"$APP_NAME\" buttons {\"打开日志\" , \"OK\"} default button \"OK\" with icon stop" 2>/dev/null
    if [ "$button returned" = "打开日志" ] 2>/dev/null; then
        open "${LOG_DIR}"
    fi
    exit 1
fi

# ── Step 7: Open native window ────────────────────────────────
APP_URL="http://localhost:$SERVER_PORT"

if [ -d "$WINDOW_APP" ]; then
    log "Launching native window applet..."
    open "$WINDOW_APP"
    
    log "App running. Close window to exit."
    while true; do
        # Check if applet process is still running
        if ! pgrep -f "Window.applet/Contents/MacOS/applet" >/dev/null 2>&1; then
            log "Window closed, exiting..."
            break
        fi
        # Check if backend died
        if ! kill -0 $BACKEND_PID 2>/dev/null; then
            log "Backend died, exiting..."
            break
        fi
        sleep 2
    done
else
    # ── Safari Fallback ───────────────────────────────────────
    log "Opening Safari in app mode (fallback)..."
    /usr/bin/osascript -e "
tell application \"Safari\"
    activate
    set w to make new document with properties {URL:\"${APP_URL}\"}
end tell
" 2>/dev/null
    
    log "App running in Safari mode. Close Safari window or Ctrl+C to exit."
    wait $BACKEND_PID 2>/dev/null || true
fi

log "Exiting..."
